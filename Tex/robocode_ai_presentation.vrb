\frametitle{Training Loop Snapshot}
\begin{lstlisting}[style=pycode]
state = self._encode_state()
action = self.agent.select_action(state)

if self.prev_state is not None:
  if not self.eval_mode:
    self.agent.push_transition(
      self.prev_state,
      self.prev_action,
      state,
      self.step_reward,
      done=False,
    )

self._execute_action(action)
\end{lstlisting}
\vspace{0.1cm}
\small In eval mode, no replay writes and no optimizer updates are performed.
